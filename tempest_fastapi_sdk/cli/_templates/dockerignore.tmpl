# .dockerignore — generated by `tempest new` for __PROJECT_NAME__.
# Keep the build context small and never bake secrets or local state
# into the image.

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Virtualenv (the image builds its own /app/.venv)
.venv/
venv/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Local state — never ship into the image
.env
*.db
*.sqlite3
logs/

# VCS / editors
.git/
.gitignore
.idea/
.vscode/

# Docs / CI that the runtime never needs
docs/
.github/
