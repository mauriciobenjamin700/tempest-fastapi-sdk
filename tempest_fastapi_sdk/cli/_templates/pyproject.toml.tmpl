[project]
name = "__PROJECT_NAME__"
version = "0.1.0"
description = "FastAPI service scaffolded with tempest-fastapi-sdk."
readme = "README.md"
requires-python = ">=3.11"
authors = [{ name = "you", email = "you@example.com" }]
dependencies = [
    "__SDK_DEP__",
    "uvicorn>=0.30.0",
    # SQLite async driver — the default DATABASE_URL uses sqlite+aiosqlite.
    "aiosqlite>=0.20.0",
    # PostgreSQL async driver — docker-compose always ships Postgres.
    # Uncomment when you switch DATABASE_URL to postgresql+asyncpg://...
    # "asyncpg>=0.30.0",
]

[dependency-groups]
dev = [
    "mypy>=1.13.0",
    "pytest>=8.3.3",
    "pytest-asyncio>=0.24.0",
    "pytest-cov>=6.0.0",
    "ruff>=0.8.0",
    "httpx>=0.28.1",
]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src"]

[tool.ruff]
line-length = 88
target-version = "py311"
src = ["src", "tests"]

[tool.ruff.lint]
# ANN forces every function/method to be annotated. ANN401 (forbid
# ``Any``) stays off -- ``Any`` is a valid annotation; the point is that
# things ARE annotated, not that they avoid ``Any``. ANN002/ANN003 skip
# ``*args`` / ``**kwargs`` noise.
select = ["E", "W", "F", "I", "B", "C4", "UP", "N", "SIM", "RUF", "ANN"]
ignore = ["B008", "B006", "ANN401", "ANN002", "ANN003"]

[tool.ruff.lint.isort]
# ``src`` is the first-party namespace (src-layout). Without this, ruff
# groups ``from src... import`` with third-party packages.
known-first-party = ["src"]

[tool.ruff.lint.per-file-ignores]
"tests/*" = ["S101"]
"**/__init__.py" = ["F401"]

[tool.ruff.format]
quote-style = "double"
indent-style = "space"

[tool.mypy]
python_version = "3.11"
strict = true
plugins = ["pydantic.mypy"]

[[tool.mypy.overrides]]
module = ["tests.*"]
disallow_untyped_defs = false

[tool.tempest]
# How strictly `tempest lint` / `fix` / `type` / `check` enforce typing.
# lenient = no extra rules; standard = require annotations + mypy
# disallow-untyped-defs; strict = full ANN set + mypy --strict.
# ANN401 (Any) is never enabled at any level. Override per run with
# `tempest check --strictness strict`.
typing_strictness = "standard"

[tool.pytest.ini_options]
asyncio_mode = "auto"
testpaths = ["tests"]
python_files = ["test_*.py"]
python_classes = ["Test*"]
python_functions = ["test_*"]
addopts = ["-ra", "--strict-markers", "--strict-config"]
