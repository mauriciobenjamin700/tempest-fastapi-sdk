"""``create_app()`` — wires middleware, exception handlers, health and routers."""

from __future__ import annotations

from contextlib import asynccontextmanager
from collections.abc import AsyncIterator

from fastapi import FastAPI

from tempest_fastapi_sdk import (
    AdminModel,
    AdminSite,
    RequestIDMiddleware,
    UserModelAuthBackend,
    apply_cors,
    configure_logging,
    make_admin_router,
    make_health_router,
    make_logs_router,
    register_exception_handlers,
)

from src.api.dependencies import db
from src.core.settings import settings
from src.db.models import UserModel

configure_logging(
    level=settings.LOG_LEVEL,
    json_output=settings.LOG_JSON,
    log_dir=settings.LOG_DIR,
)


@asynccontextmanager
async def lifespan(_: FastAPI) -> AsyncIterator[None]:
    """Open and close shared resources for the app lifecycle."""
    await db.connect()
    try:
        yield
    finally:
        await db.disconnect()


def create_app() -> FastAPI:
    """Build the configured FastAPI instance.

    Returns:
        FastAPI: A fully wired application ready for uvicorn.
    """
    app = FastAPI(
        title="__PROJECT_NAME__",
        version="0.1.0",
        lifespan=lifespan,
    )

    app.add_middleware(RequestIDMiddleware)
    apply_cors(app, settings)
    register_exception_handlers(app)

    app.include_router(
        make_health_router(db=db, version="0.1.0"),
    )
    app.include_router(
        make_logs_router(
            log_dir=settings.LOG_DIR,
            token_secret=settings.TOKEN_SECRET,
        ),
    )

    # Admin panel — requires the [admin] extra plus a UserModel row
    # with ``is_admin=True``. Bootstrap one after running the first
    # Alembic migration:
    #   uv run alembic upgrade head
    #   uv run python -c "..."  # set hashed_password + is_admin=True
    admin_site = AdminSite(title="__PROJECT_NAME__ admin")
    admin_site.register(AdminModel(model=UserModel))
    app.include_router(
        make_admin_router(
            admin_site,
            db=db,
            auth_backend=UserModelAuthBackend(user_model=UserModel),
            secret_key=settings.JWT_SECRET,
            cookie_secure=not settings.SERVER_DEBUG,
            show_logs=True,
            log_dir=settings.LOG_DIR,
        ),
    )

    from src.api.routers import router as api_router

    app.include_router(api_router, prefix="/api")

    return app
