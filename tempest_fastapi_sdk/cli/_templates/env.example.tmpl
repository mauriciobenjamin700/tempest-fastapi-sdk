# Server
SERVER_HOST=__HOST__
SERVER_PORT=__PORT__
SERVER_DEBUG=false
SERVER_RELOAD=false

# Logging
LOG_LEVEL=INFO
LOG_JSON=true
# Per-level + 500.log files written here. Empty disables file logging.
LOG_DIR=logs

# Database (SQLite by default — switch to PostgreSQL in production)
# Read by both the app and `tempest db`. alembic.ini ships with
# sqlalchemy.url empty on purpose — credentials never enter VCS.
DATABASE_URL=sqlite+aiosqlite:///./app.db

# Auth (override before running in production)
JWT_SECRET=change-me-change-me-change-me-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_SECONDS=3600
JWT_REFRESH_TTL_SECONDS=604800

# Shared-secret token dependency (empty disables the check — dev only)
TOKEN_SECRET=

# CORS — never ship ["*"] to production
CORS_ORIGINS=["http://localhost:3000"]
CORS_ALLOW_CREDENTIALS=true
